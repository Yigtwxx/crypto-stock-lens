# ─────────────────────────────────────────────────────────────────────────────
# Oracle-X Frontend — Environment Configuration
# Copy this file to `.env.local` and fill in your own values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API + WebSocket URLs
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/prices

# Supabase (client-side auth). Use the publishable/anon key only — never the
# service-role key on the frontend.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key
